{
  "semi": true,
  "singleQuote": false,
  "endOfLine": "auto",
  "printWidth": 120,
  "jsxSingleQuote": false,
  "trailingComma": "es5",
  "bracketSpacing": true,
  "jsxBracketSameLine": false,
  "arrowParens": "always",
  "insertPragma": false,
  "tabWidth": 2,
  "useTabs": false,
  "HTMLWhitespaceSensitivity": "strict"
}
